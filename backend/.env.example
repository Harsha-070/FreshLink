# ============================================
# FreshLink Backend Environment Variables
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Firebase Configuration (Option 1: Service Account Key File)
# Place serviceAccountKey.json in the backend/ folder

# Firebase Configuration (Option 2: Environment Variable)
# Paste the entire JSON content of your service account key
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Razorpay Payment Gateway (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Push Notifications (optional)
# For web push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
