{
  "name": "freshlink-pro",
  "version": "1.0.0",
  "description": "Hyperlocal Fresh Produce Supply & Waste Reduction Platform",
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "frontend:dev": "cd frontend && npx vite",
    "frontend:build": "cd frontend && npx vite build",
    "frontend:preview": "cd frontend && npx vite preview",
    "frontend:install": "cd frontend && npm install",
    "backend:dev": "cd backend && node --watch server.js",
    "backend:start": "cd backend && node server.js",
    "backend:install": "cd backend && npm install",
    "install:all": "npm run frontend:install && npm run backend:install",
    "build": "npm run frontend:build",
    "start": "cd backend && NODE_ENV=production node server.js",
    "start:dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
